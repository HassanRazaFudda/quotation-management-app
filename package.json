{
  "name": "junaidi-quotations",
  "private": true,
  "version": "0.1.0",
  "description": "Hajj quotation system for Junaidi Air Travels",
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @junaidi/api dev",
    "dev:web": "pnpm --filter @junaidi/web dev",
    "seed": "pnpm --filter @junaidi/db seed",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
