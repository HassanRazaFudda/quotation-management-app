# Copy to .env.local for development.

# MongoDB. Local default is mongodb://127.0.0.1:27017/junaidi
MONGODB_URI=mongodb://127.0.0.1:27017/junaidi

# Must be at least 32 characters. The API refuses to start without it.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Comma-separated origins allowed to call this API (the frontend).
ALLOWED_ORIGINS=http://localhost:3000

# Only used by the seed script, to create the first admin account.
SEED_ADMIN_EMAIL=admin@junaidi.local
SEED_ADMIN_PASSWORD=
